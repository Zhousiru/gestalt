{
  "name": "@gestalt/app",
  "version": "0.0.0",
  "private": true,
  "description": "Main AI-native persona chatbot runtime host and connector-facing application.",
  "type": "module",
  "license": "UNLICENSED",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "node scripts/build.mjs",
    "verify:live-api": "tsx src/live/server.verify.ts",
    "verify:onebot-ingress": "tsx src/connectors/onebot/ingressQueue.verify.ts && tsx src/connectors/onebot/transport.verify.ts",
    "verify:session": "tsx src/session/sessionJournal.verify.ts && tsx src/runtime/runtimeSessionPin.verify.ts",
    "verify:effects": "tsx src/tools/executeActions.verify.ts && tsx src/runtime/outboundMessages.verify.ts && tsx src/runtime/outboundCommitBarrier.verify.ts && tsx src/runtime/activeRollout.verify.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.5",
    "@gestalt/live-contracts": "workspace:*",
    "@lancedb/lancedb": "^0.31.0",
    "ai": "^7.0.16",
    "dotenv": "^17.4.2",
    "just-bash": "^3.0.2",
    "sharp": "^0.35.3",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@gestalt/trace": "workspace:*",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1"
  }
}
