{
  "name": "@gestalt/app",
  "version": "0.0.0",
  "private": true,
  "description": "Main AI-native persona chatbot runtime host and connector-facing application.",
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "esbuild src/main.ts --bundle --platform=node --format=esm --target=node22 --outfile=dist/main.js",
    "typecheck": "tsc --noEmit",
    "start": "node dist/main.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.5",
    "ai": "^7.0.16",
    "dotenv": "^17.4.2",
    "just-bash": "^3.0.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1"
  }
}
