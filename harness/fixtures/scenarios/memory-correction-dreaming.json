{
  "id": "memory-correction-dreaming",
  "description": "A real dreaming pass edits a wrong user memory instead of appending a contradictory note.",
  "homeFixture": "harness/fixtures/homes/simple-group-test",
  "memoriesFixture": "harness/fixtures/memories/memory-correction",
  "model": {
    "kind": "configured_ai_sdk"
  },
  "dreaming": {
    "kind": "configured_bash_memory"
  },
  "events": [
    {
      "conversationId": "memory-group",
      "conversationName": "Memory Harness Group",
      "messageId": "memory-correction-message-1",
      "senderId": "alice",
      "senderName": "Alice",
      "text": "小格，我其实一直不喜欢 rigid memory templates。相比固定一大堆 sections，我更偏好由 dreaming prompts 和 harness evidence 塑造的 lightweight memory。",
      "mentionsBot": true,
      "windowReason": "mention"
    }
  ],
  "expectations": {
    "session": {
      "conversations": 1,
      "windows": 1,
      "turns": 1,
      "turnStatus": "completed",
      "loopExits": 1,
      "steerCount": 0,
      "eventIds": ["memory-correction-message-1"]
    },
    "modelInput": {
      "contains": [
        "Incorrect preference",
        "rigid memory templates",
        "lightweight memory"
      ]
    },
    "modelExchange": {
      "minExchanges": 3,
      "minResponses": 3,
      "purposeIncludes": ["agent_action", "dreaming"],
      "responseContains": [
        "\"name\":\"bash\"",
        "/memories/users/alice/index.md",
        "lightweight memory"
      ]
    },
    "rollout": {
      "rollouts": 1,
      "spans": [
        "memory.inject",
        "context.compile",
        "model.decide",
        "tool.execute",
        "dream.run"
      ]
    },
    "memory": {
      "homeBeforeContains": [
        {
          "path": "memories/users/alice/index.md",
          "contains": "Alice prefers rigid memory templates"
        }
      ],
      "homeAfterContains": [
        {
          "path": "memories/users/alice/index.md",
          "contains": "lightweight memory"
        }
      ],
      "homeAfterDoesNotContain": [
        {
          "path": "memories/users/alice/index.md",
          "contains": "Alice prefers rigid memory templates with many fixed sections."
        }
      ],
      "injectedMemoryPaths": [
        "self/index.md",
        "users/alice/index.md"
      ],
      "injectedMemoryContains": [
        "Incorrect preference",
        "rigid memory templates"
      ],
      "dreamCommandsContain": [
        "/memories/users/alice/index.md"
      ],
      "dreamChangedFiles": [
        "users/alice/index.md"
      ]
    }
  }
}
