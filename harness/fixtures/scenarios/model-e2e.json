{
  "id": "model-e2e",
  "description": "A configured AI SDK model sees a simple test persona and a direct group mention, then proposes a group reply.",
  "homeFixture": "harness/fixtures/homes/simple-group-test",
  "memoriesFixture": "harness/fixtures/memories/simple-group-test",
  "model": {
    "kind": "configured_ai_sdk"
  },
  "events": [
    {
      "conversationId": "harness-group",
      "conversationName": "Harness Group",
      "messageId": "message-1",
      "senderId": "alice",
      "senderName": "Alice",
      "text": "gestalt 请你直接回复一句：这个测试 persona 可以先这样。",
      "mentionsBot": true,
      "windowReason": "mention"
    }
  ],
  "expectations": {
    "session": {
      "conversations": 1,
      "events": 2,
      "selfMessages": 1,
      "windows": 1,
      "turns": 1,
      "turnStatus": "completed",
      "loopExits": 1,
      "loopExitReasons": ["idle_timeout"],
      "steerCount": 0,
      "eventIds": ["message-1"],
      "phases": [
        "memory_injecting",
        "context_compiling",
        "model_running",
        "executing",
        "completed"
      ]
    },
    "action": {
      "toolName": "send_group_message",
      "groupId": "harness-group",
      "textMinLength": 1,
      "textMaxLength": 160,
      "textDoesNotMatch": "```"
    },
    "tools": {
      "connectorSideEffects": 0
    },
    "modelInput": {
      "requests": 2,
      "contains": [
        "Harness Test Friend",
        "Self memory baseline",
        "Alice memory baseline",
        "Alice (user_id=alice, message_id=message-1, mentioned you)",
        "mentioned you",
        "gestalt 请你直接回复一句：这个测试 persona 可以先这样。"
      ],
      "doesNotContain": [
        "Initial conversation window",
        "New conversation window",
        "Decision target:",
        "context=current_window",
        "mentions_bot=true"
      ],
      "tools": ["send_group_message", "say_nothing"]
    },
    "modelExchange": {
      "exchanges": 2,
      "responses": 2,
      "maxToolCallsPerResponse": 1,
      "purposes": ["agent_action", "agent_action"],
      "responseContains": ["send_group_message"],
      "responseDoesNotContain": ["\"toolName\":\"leave\""]
    },
    "rollout": {
      "rollouts": 1,
      "spans": [
        "memory.inject",
        "context.compile",
        "model.decide",
        "tool.execute"
      ],
      "modelResponseContains": ["send_group_message"],
      "modelResponseDoesNotContain": ["\"toolName\":\"leave\""]
    }
  }
}
