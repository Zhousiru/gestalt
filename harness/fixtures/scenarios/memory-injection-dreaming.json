{
  "id": "memory-injection-dreaming",
  "description": "A real model naturally infers durable design direction and user preferences without logging the interaction.",
  "homeFixture": "harness/fixtures/homes/simple-group-test",
  "memoriesFixture": "harness/fixtures/memories/simple-group-test",
  "model": {
    "kind": "configured_ai_sdk"
  },
  "dreaming": {
    "kind": "configured_bash_memory"
  },
  "events": [
    {
      "conversationId": "memory-group",
      "conversationName": "Memory Harness Group",
      "messageId": "memory-message-1",
      "senderId": "alice",
      "senderName": "Alice",
      "text": "gestalt，我们的 memory subsystem 方向现在很明确了：用 file-backed Markdown，dreaming 通过 /memories VFS 里的 bash 来维护，而不是 JSON command lists。我会继续参与这套 memory design；对我来说，harness 必须展示真实 model input/output 和可检查的 artifact evidence，不能只放 placeholders。",
      "mentionsBot": true,
      "windowReason": "mention"
    }
  ],
  "expectations": {
    "session": {
      "conversations": 1,
      "windows": 1,
      "turns": 1,
      "turnStatus": "completed",
      "loopExits": 1,
      "steerCount": 0,
      "eventIds": ["memory-message-1"],
      "phases": [
        "memory_injecting",
        "context_compiling",
        "model_running",
        "executing",
        "completed"
      ]
    },
    "modelInput": {
      "contains": [
        "Self memory baseline",
        "Alice memory baseline",
        "artifact evidence",
        "placeholders"
      ]
    },
    "modelExchange": {
      "minExchanges": 3,
      "minResponses": 3,
      "purposeIncludes": ["agent_action", "dreaming"],
      "responseContains": [
        "\"name\":\"bash\"",
        "/memories/self/index.md",
        "/memories/users/alice/index.md",
        "Markdown",
        "artifact evidence"
      ]
    },
    "promptCache": {
      "enabled": true,
      "appendOnly": true,
      "singleSession": true,
      "singleSystemMessage": true,
      "requestBodyEnabled": true,
      "includeDreaming": true,
      "terminalDreamingContinuation": true,
      "minHitResponses": 1,
      "minReadTokens": 1,
      "minFirstDreamingReadTokens": 1,
      "minDreamingHitResponses": 1,
      "minDreamingReadTokens": 1
    },
    "rollout": {
      "rollouts": 1,
      "spans": [
        "memory.inject",
        "context.compile",
        "model.decide",
        "tool.execute",
        "dream.run"
      ]
    },
    "memory": {
      "homeBeforeContains": [
        {
          "path": "memories/self/index.md",
          "contains": "Self memory baseline"
        },
        {
          "path": "memories/users/alice/index.md",
          "contains": "Alice memory baseline"
        }
      ],
      "homeAfterContains": [
        {
          "path": "memories/users/alice/index.md",
          "contains": "artifact evidence"
        }
      ],
      "injectedMemoryPaths": [
        "self/index.md",
        "users/alice/index.md"
      ],
      "injectedMemoryContains": [
        "Self memory baseline",
        "Alice memory baseline"
      ],
      "dreamCommandsContain": [
        "/memories",
        "Markdown",
        "artifact evidence"
      ],
      "dreamChangedFiles": ["users/alice/index.md"]
    }
  }
}
